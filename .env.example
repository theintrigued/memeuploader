# --- Insider Memes ---
INSIDERMEMES_API_TOKEN=your_insidermemes_token

# --- Trending topic suggestions (Claude + web search) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Shared secret so randoms can't hit your endpoints ---
APP_SECRET=choose_a_long_random_string

# --- YouTube (Google Cloud Console) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Instagram (via ShortSync — connect Instagram at shortsync.app/settings?section=connections) ---
SHORTSYNC_API_KEY=

# --- TikTok (Content Posting API) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# Which platforms to post to (comma separated): youtube,instagram,tiktok
POST_TO=youtube,instagram,tiktok

PORT=3000
