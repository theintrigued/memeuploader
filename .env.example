# --- Insider Memes ---
INSIDERMEMES_API_TOKEN=your_insidermemes_token

# --- Trending topic suggestions (Claude + web search) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Persisted prompt storage (Upstash Redis free tier) ---
# Create a free database at upstash.com, copy both values from its dashboard.
# Without these, trending suggestions still work but won't survive a restart.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Shared secret so randoms can't hit your endpoints ---
APP_SECRET=choose_a_long_random_string

# --- YouTube, Instagram — posted via ShortSync ---
# Connect each platform at shortsync.app/settings?section=connections, then
# generate a key at shortsync.app/settings?section=api
SHORTSYNC_API_KEY=

# --- TikTok (direct via TikTok's Content Posting API) ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REFRESH_TOKEN=

# Which platforms to post to (comma separated): youtube,instagram,tiktok
POST_TO=youtube,instagram,tiktok

# --- Autopilot (fully autonomous posting) ---
# ON/OFF is controlled live from the frontend switch, NOT here — these are
# just the schedule shape. Autopilot defaults to OFF until you flip the switch.
AUTOPILOT_POSTS_PER_DAY=20
AUTOPILOT_WINDOW_HOURS=2
# Your timezone as a fixed UTC offset in hours (e.g. 4 for Gulf Standard Time /
# Dubai). Used only to decide where "midnight" falls for the daily schedule.
AUTOPILOT_TZ_OFFSET_HOURS=4
# Defaults to POST_TO above if unset — override if autopilot should post to a
# different set of platforms than manual generation.
AUTOPILOT_PLATFORMS=

PORT=3000
